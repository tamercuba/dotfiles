#!/usr/bin/env bb
(require '[babashka.process :as p]
         '[clojure.string :as s])

(defn- parse-session-names [sessions]
  (map #(first (s/split % #":")) sessions))

(defn- session-name []
  (let [result (p/sh "tmux" "ls")]
    (if (zero? (:exit result))
      (let [sessions (-> result :out s/split-lines parse-session-names)]
        (str "default" (+ 1 (count sessions))))
      "default")))

(defn- main []
  (p/exec "tmux" "new-session" "-s" (session-name)))

(main)
