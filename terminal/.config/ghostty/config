# Font
font-family = JetBrains Mono
font-size = 14

# Machine-specific overrides (not tracked by git)
config-file = ?local

# Window
macos-titlebar-style = hidden
window-padding-x = 0
window-padding-y = 0

# Shell (tmux auto-attach)
command = /bin/zsh -lc /Users/tamer.cuba/.local/bin/tmux_attach_clj

# Cursor
cursor-style = block
cursor-style-blink = false
custom-shader = shaders/cursor_tail.glsl

# Behavior
confirm-close-surface = false
macos-option-as-alt = false

# Keybindings
keybind = ctrl+shift+v=paste_from_clipboard
keybind = super+shift+q=unbind

# Colorscheme
config-file = themes/catppuccin-macchiato.conf
