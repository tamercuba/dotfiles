#!/usr/bin/env bb
(require '[babashka.process :as p]
         '[clojure.string :as s]
         '[cheshire.core :as json])

(defn devices []
  (-> (p/sh "wpctl" "status")
      :out
      s/split-lines
      (->> (drop-while #(not (s/includes? % "Sinks:")))
           (drop 1)
           (take-while #(not (s/includes? % "Sources:")))
           (keep #(re-find #"(\*?)\s+(\d+)\.\s+(.+?)\s+\[vol:" %))
           (map (fn [[_ default? id name]]
                  {:id id
                   :name (s/trim name)
                   :default? (not (s/blank? default?))}))
           (sort-by :id))))

(defn next-device [sound-devices]
  (if (:default? (last sound-devices))
    (first sound-devices)
    (loop [targets sound-devices
           current (first targets)
           next-   (second targets)]
      (cond
        (nil? current)      nil
        (nil? next-)        current
        (:default? current) next-
        :else               (recur (rest targets)
                                   (second targets)
                                   (nth targets 2 nil))))))

(defn set-new-default-sink [device]
  (p/sh "wpctl" "set-default" (:id device)))

(defn audio-stream-ids []
  (->> (p/sh "pw-dump")
       :out
       json/parse-string
       (filter #(and (= "PipeWire:Interface:Node" (get % "type"))
                     (= "Stream/Output/Audio" (get-in % ["info" "props" "media.class"]))))
       (map #(str (get % "id")))))

(defn move-streams [sink-id]
  (doseq [stream-id (audio-stream-ids)]
    (p/sh "pw-metadata" stream-id "target.node" sink-id)))

(defn notify [device]
  (if (nil? device)
    (p/sh "notify-send" "🔊 Audio" "Device not found")
    (p/sh "notify-send" "🔊 Audio" (:name device))))

(defn- ^:private -main []
  (let [sound-devices   (devices)
        selected-device (next-device sound-devices)]
    (set-new-default-sink selected-device)
    (move-streams (:id selected-device))
    (notify selected-device)))

(-main)
