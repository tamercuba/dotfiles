#!/usr/bin/env bb
(require '[babashka.process :as p]
         '[clojure.string :as s])

(def hda-device "/dev/snd/hwC1D0")
(def node-id    "45")

(def outputs
  [{:name       "Monitors (traseira)"
    :route      3
    :enable     {:node "0x14" :value "0x40"}
    :disable    {:node "0x1b" :value "0x00"}}
   {:name       "Fone (frontal)"
    :route      4
    :enable     {:node "0x1b" :value "0xc0"}
    :disable    {:node "0x14" :value "0x00"}}])

(defn hda-verb [node value]
  (p/sh "hda-verb" hda-device node "SET_PIN_WIDGET_CONTROL" value))

(defn current-rear-pin []
  (->> (p/sh "cat" "/proc/asound/card1/codec#0")
       :out
       s/split-lines
       (drop-while #(not (s/includes? % "Line Out at Ext Rear")))
       (drop-while #(not (s/includes? % "Pin-ctls")))
       first
       (re-find #"0x([0-9a-f]+):")
       second))

(defn current-output []
  (if (= "00" (current-rear-pin))
    (second outputs)   ; rear disabled = earphones active
    (first outputs)))  ; rear enabled  = monitors active

(defn next-output [current]
  (if (= current (first outputs))
    (second outputs)
    (first outputs)))

(defn switch! [target]
  (hda-verb (get-in target [:enable  :node]) (get-in target [:enable  :value]))
  (hda-verb (get-in target [:disable :node]) (get-in target [:disable :value]))
  (p/sh "wpctl" "set-route" node-id (str (:route target))))

(defn notify [output]
  (p/sh "notify-send" "🔊 Audio" (:name output)))

(defn -main []
  (let [target (next-output (current-output))]
    (switch! target)
    (notify target)))

(-main)
